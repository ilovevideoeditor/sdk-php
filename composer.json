{
  "name": "ilovevideoeditor/sdk",
  "description": "Official PHP SDK for the iLoveVideoEditor cloud video rendering API — render MP4/WebM videos programmatically from JSON scene descriptions and templates",
  "type": "library",
  "keywords": ["video", "video-rendering", "video-api", "video-generation", "programmatic-video", "video-editing", "video-automation", "cloud-rendering", "render-api", "mp4", "sdk", "api-client", "ilovevideoeditor"],
  "support": {
    "issues": "https://github.com/ilovevideoeditor/sdk-php/issues",
    "source": "https://github.com/ilovevideoeditor/sdk-php",
    "docs": "https://ilovevideoeditor.com/docs/sdks"
  },
  "homepage": "https://ilovevideoeditor.com",
  "license": "MIT",
  "authors": [
    {
      "name": "iLoveVideoEditor",
      "email": "support@ilovevideoeditor.com"
    }
  ],
  "require": {
    "php": ">=8.1",
    "ext-curl": "*",
    "ext-json": "*",
    "ext-mbstring": "*",
    "guzzlehttp/guzzle": "^7.3",
    "guzzlehttp/psr7": "^1.7 || ^2.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^8.0 || ^9.0",
    "friendsofphp/php-cs-fixer": "^3.5"
  },
  "autoload": {
    "psr-4": {
      "iLoveVideoEditor\\SDK\\": "src/",
      "iLoveVideoEditorSDK\\": "src/Generated/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "iLoveVideoEditor\\SDK\\Test\\": "tests/"
    }
  }
}
